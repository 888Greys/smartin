generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  balance       Float    @default(0.00)
  totalEarnings Float    @default(0.00)
  totalDeposits Float    @default(0.00)
  totalWithdrawals Float @default(0.00)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Profile fields
  fullName      String?
  phone         String?
  idNumber      String?
  dateOfBirth   DateTime?
  profilePhoto  String?
  tier          String   @default("basic") // basic, premium, vip
  
  // KYC fields
  gender        String?  // male, female, other
  occupation    String?
  address       String?
  
  // Referral system
  referralCode     String   @unique @default("")
  referredBy       String?
  referralCount    Int      @default(0)
  referralEarnings Float    @default(0.00)

  transactions Transaction[]
  passkeys     Passkey[]
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Float
  status    String   @default("pending")
  reference String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Passkey {
  id                  String   @id @default(cuid())
  userId              String
  credentialId        String   @unique
  credentialPublicKey Bytes
  counter             BigInt
  transports          String[] @default([])
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model OtpCode {
  id          String    @id @default(cuid())
  email       String    @unique
  otp         String
  expiresAt   DateTime
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
}

model PasskeyChallenge {
  id        String   @id @default(cuid())
  key       String   @unique
  challenge String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
